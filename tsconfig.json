{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "rootDir": ".",
        "declaration": false,
        "verbatimModuleSyntax": true,
        "sourceMap": true,
        "lib": ["ES2022"],
        "types": ["node"]
    },
    "include": ["examples/**/*"],
    "exclude": ["node_modules", "dist"]
}
